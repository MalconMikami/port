# ============================================
# Port — Environment Configuration
# ============================================
# Copie este arquivo para .env e ajuste os valores
#
# Modo produção: DOMAIN=seudominio.com, JWT_SECRET=<senha-forte>
# Modo dev: DOMAIN=localhost, EXTERNAL_PORT=10000

# ── Server ──
PORT=3000
EXTERNAL_PORT=10000
DOMAIN=localhost

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_NAME=port
DB_USER=postgres
DB_PASSWORD=port_secret

# ── Session ──
# Produção: gere com `openssl rand -hex 32`
JWT_SECRET=dev-secret-change-in-production

# ── AI (opcional) ──
AI_ENDPOINT_URL=
AI_API_KEY=

# ── Storage ──
SITES_DIR=/data/sites
UPLOADS_DIR=/data/uploads
